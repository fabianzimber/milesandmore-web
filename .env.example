# === Vercel / milesandmore-web ===
# Canonical public web URL. Vercel owns this value.
WEB_APP_URL=http://localhost:3000

# Railway canonical backend URL copied here so web server routes/proxies can reach the backend.
# Railway remains the source of truth for this value.
BACKEND_PUBLIC_URL=http://localhost:4000
NEXT_PUBLIC_BOT_API_URL=http://localhost:4000

# Shared server-to-server secret. Must match Railway exactly.
MILESANDMORE_INTERNAL_API_SECRET=replace_with_shared_secret_used_by_web_and_backend

# Twitch application credentials (single app — created once in the Twitch Developer Console,
# may be registered under the bot account but it is still just one application).
# Used on Vercel for NextAuth/admin login.
TWITCH_APP_CLIENT_ID=your_twitch_app_client_id
TWITCH_APP_CLIENT_SECRET=your_twitch_app_client_secret

# NextAuth / admin access (Vercel only)
AUTH_SECRET=generate_a_random_secret_here
ADMIN_TWITCH_IDS=your_twitch_user_id

# Split note:
# - Legacy combined-app APP_URL / NEXT_PUBLIC_APP_URL collapse into WEB_APP_URL.
# - Do not place bot, Redis, QStash, or SimLink secrets in Vercel.
